# SafeCommute web/ environment template.
# Copy to .env.local (git-ignored) and fill in real values before running
# `npm run dev` or building for deploy. Every secret below is required for the
# matching feature to work; omit and the route will throw a descriptive error.

# ── Supabase (auth + storage + postgres) ─────────────────────────────────────
# Project URL from https://app.supabase.com/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key — safe to expose in the browser, paired with RLS.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Service-role key — NEVER expose in the browser. Used by server-side routes
# and by the worker (worker/.env.example) to bypass RLS.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Stripe (one-time payment flow) ───────────────────────────────────────────
# Paper CLAUDE.md §"Website backend state" documents both tiers as one-time.
# The env-var name `STRIPE_PRICE_SUBSCRIPTION` is a historical artefact — the
# tier is functionally the "site unlock" one-time product, not a recurring
# subscription. Do NOT flip either to recurring without an explicit decision.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_SUBSCRIPTION=price_...   # €100 one-time "Site unlock"
STRIPE_PRICE_PER_RUN=price_...        # €23 one-time per-run credit

# ── Base URL used in Stripe redirect/success URLs + email links ──────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
