# SafeCommute fine-tune worker environment template.
# Copy to worker/.env and fill in real values. The systemd unit reads this
# file via EnvironmentFile= — IMPORTANT: systemd does NOT strip inline
# comments, so do NOT put `# ...` after a `KEY=VALUE` line, or the whole
# trailing string becomes part of the value. Put comments on their own
# lines above the variable, like this file does.

# ── Supabase service-role credentials ────────────────────────────────────
# The worker uses the service-role key to bypass RLS on:
#   - PATCH finetune_jobs (status queued→running→succeeded|failed)
#   - SELECT audio_clips for a site
#   - Storage read on audio-uploads, write on models-deliverable
#   - INSERT worker_logs
# NEVER ship this key in a browser bundle.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Loop cadence + concurrency ───────────────────────────────────────────
# Sleep between polls when there are no queued jobs.
WORKER_POLL_INTERVAL_S=15

# Keep this at 1 on the Ryzen box. Training on CPU takes 10–20 min per
# job and parallel runs thrash MKL / oversubscribe cores.
WORKER_CONCURRENCY=1

# ── Bucket overrides (only needed if the migrations rename them) ─────────
CLIPS_BUCKET=audio-uploads
MODEL_BUCKET=models-deliverable

# ── Fine-tune recipe (tweak-3 from paper §1.4) ───────────────────────────
# Override only if you know why you're deviating from the paper's recipe.
FT_KEEP_SAFE_RATIO=0.1
FT_EPOCHS=20
FT_LR=1e-4
MAJORITY_K=2

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
