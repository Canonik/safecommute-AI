# SafeCommute fine-tune worker environment template.
# Copy to worker/.env and `systemctl --user set-environment ...` the values,
# or source the file into the unit's Environment= lines.
#
# Every variable below is required for a full end-to-end run. The worker is
# self-hosted by default (Ryzen 7 7435HS dev box, systemd user unit); see
# `systemd/safecommute-worker.service` and `worker/README.md`.

# ── Supabase service-role credentials ────────────────────────────────────────
# The worker uses the service-role key so it can bypass RLS on:
#   - PATCH finetune_jobs (status queued→running→succeeded|failed)
#   - SELECT audio_clips for a site
#   - Storage read on audio-uploads, write on models-deliverable
#   - INSERT worker_logs
# NEVER ship this in a browser bundle.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# ── Loop cadence + concurrency ───────────────────────────────────────────────
WORKER_POLL_INTERVAL_S=15           # sleep between polls when no queued job
WORKER_CONCURRENCY=1                # keep 1 on the Ryzen box; training on
                                    # CPU takes 10–20 min and parallel runs
                                    # thrash MKL.

# ── Bucket overrides (only needed if the migrations rename them) ─────────────
CLIPS_BUCKET=audio-uploads
MODEL_BUCKET=models-deliverable

# ── Fine-tune recipe (tweak-3 from paper §1.4) ───────────────────────────────
# Override only if you know what you're changing — the defaults match the
# recipe cited in the paper's Phase-1 plateau-closing result.
FT_KEEP_SAFE_RATIO=0.1
FT_EPOCHS=20
FT_LR=1e-4
MAJORITY_K=2

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
